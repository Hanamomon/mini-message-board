<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Message Board</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <ul>
  <% messages.forEach(message =>  { %>
    <%- include('message', { message: message }) %>
  <% }) %>
  </ul>
  <a href="/new">New</a>
</body>
</html>